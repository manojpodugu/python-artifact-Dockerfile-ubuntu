""app.py"" CODE:
--------------------------------------------------------------------------------------------------------------------------------------------------------------
from flask import Flask, jsonify

app = Flask(__name__)

employees = [
    {"id": 1, "name": "Alice"},
    {"id": 2, "name": "Bob"},
    {"id": 3, "name": "Charlie"}
]

@app.route("/")
def home():
    return "Employee API is running"

@app.route("/health")
def health():
    return jsonify({"status": "UP"})

@app.route("/employees")
def get_employees():
    return jsonify(employees)

if __name__ == "__main__":
    app.run(host="0.0.0.0", port=5000)

